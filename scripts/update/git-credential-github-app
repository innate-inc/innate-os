#!/bin/bash
# Git credential helper for GitHub App authentication

# Parse git credential input
while IFS='=' read -r key value; do
    case "$key" in
        host) host="$value" ;;
        protocol) protocol="$value" ;;
    esac
done

# Only handle github.com
if [ "$host" != "github.com" ]; then
    exit 0
fi

# Generate token using GitHub App
token=$(/home/jetson1/innate-os/scripts/update/github-app-auth.sh 2>/dev/null)

if [ -n "$token" ]; then
    echo "username=x-access-token"
    echo "password=$token"
fi



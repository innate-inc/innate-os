# Environment variables template for Maurice robot
# Copy this file to .env and fill in your actual values
# The .env file is git-ignored for security

# =============================================================================
# Innate Brain Connection
# =============================================================================
BRAIN_WEBSOCKET_URI=wss://brain.innate.bot
BRAIN_WEBSOCKET_URI_SIM=ws://host.docker.internal:8765
BRAIN_AUTH_TOKEN=your_auth_token_here

# =============================================================================
# Innate Services
# =============================================================================
INNATE_PROXY_URL=https://your-proxy-url.run.app
# Will be one token for both brain and services
INNATE_SERVICE_KEY=your_service_key_here
TELEMETRY_URL=https://logs.innate.bot


# ===== Service Configuration =====
# Note: These are now ROS2 launch parameters with sensible defaults.
# Only add here if you need to override at environment level.
# See brain_client.launch.py for configurable parameters:
#   - cartesia_voice_id (default: f786b574-daa5-4673-aa0c-cbe3e8534c02)
#   - openai_realtime_model (default: gpt-4o-realtime-preview)
#   - openai_realtime_url (default: wss://api.openai.com/v1/realtime)
#   - openai_transcribe_model (default: gpt-4o-mini-transcribe)

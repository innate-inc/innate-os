# Environment variables template for Maurice robot
# Copy this file to .env and fill in your actual values
# The .env file is git-ignored for security

# =============================================================================
# Innate Brain Connection
# =============================================================================
# BRAIN_WEBSOCKET_URI=wss://agent-v1.innate.bot

# =============================================================================
# Innate Services
# =============================================================================
INNATE_SERVICE_KEY=your_service_key_here
TELEMETRY_URL=https://logs.innate.bot

# Explore other voices at https://play.cartesia.ai
# CARTESIA_VOICE_ID=9fdaae0b-f885-4813-b589-3c07cf9d5fea

# set by default
# INNATE_PROXY_URL=https://proxy-v1.innate.bot
# INNATE_AUTH_URL=https://auth-v1.innate.bot
# INNATE_TRAINING_URL=https://training-v1.innate.bot
# UNINAVID_WS_URL=wss://nav-v1.innate.bot

# =============================================================================
# Telegram Bot
# =============================================================================
# Get from @BotFather on Telegram — see skills/TELEGRAM_SETUP.md
TELEGRAM_BOT_TOKEN=...

# =============================================================================
# Zapier MCP (one API key for all Zapier MCP tools)
# =============================================================================
# Same bearer token unlocks Google Calendar (skills/check_calendar.py) and any other
# Zapier MCP modules you enable for this connection. Use ZAPIER_MCP_API_KEY or
# MCP_ZAPIER_API_KEY (either name; same value).
# ZAPIER_MCP_API_KEY=
# Optional; default Zapier MCP endpoint is https://mcp.zapier.com/api/v1/connect
# ZAPIER_MCP_URL=


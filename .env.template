# Environment variables template for Maurice robot
# Copy this file to .env and fill in your actual values
# The .env file is git-ignored for security

# =============================================================================
# Innate Brain Connection
# =============================================================================
# Default points the brain_client at the production cloud-agent.
# BRAIN_WEBSOCKET_URI=wss://agent-v1.innate.bot
#
# To talk to a self-hosted cloud-agent (e.g. the molmo-nav branch of
# innate-cloud-agent running `python run_server.py` on port 8080), set:
#   BRAIN_WEBSOCKET_URI=ws://<your-cloud-agent-host>:8080
# Notes:
#   - Use ws:// (not wss://) -- run_server.py does no TLS termination.
#   - Auth still uses INNATE_SERVICE_KEY validated against BigQuery, so the
#     same key works against your local server.
#   - You can also override at launch without editing .env, e.g.:
#       ros2 launch brain_client brain_client.launch.py \
#         websocket_uri:=ws://<host>:8080 token:=$INNATE_SERVICE_KEY

# =============================================================================
# Innate Services
# =============================================================================
INNATE_SERVICE_KEY=your_service_key_here
TELEMETRY_URL=https://logs.innate.bot

# Explore other voices at https://play.cartesia.ai
# CARTESIA_VOICE_ID=9fdaae0b-f885-4813-b589-3c07cf9d5fea


# Environment variables template for Maurice robot
# Copy this file to .env and fill in your actual values
# The .env file is git-ignored for security

# ===== Proxy Configuration (Required) =====
# Innate Service Proxy URL - get from deployment
INNATE_PROXY_URL=https://your-proxy-url.run.app

# Robot authentication token - generate using scripts/generate_token.py in innate_service_proxy repo
INNATE_SERVICE_KEY=your-robot-token-here

# ===== Legacy Direct API Keys (Optional - for fallback) =====
# These are only used if proxy is not configured
# # Cartesia API key for text-to-speech functionality (deprecated - use proxy instead)
# # Get your API key from: https://cartesia.ai
# CARTESIA_API_KEY=your_api_key_here

# # OpenAI API key (deprecated - use proxy instead)
# OPENAI_API_KEY=sk-proj-your-actual-key-here

# # Google API key (if needed)
# GOOGLE_API_KEY=your_google_api_key_here

# ===== OpenAI Realtime Configuration =====
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
OPENAI_REALTIME_URL=wss://api.openai.com/v1/realtime
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# Add other sensitive environment variables here as needed

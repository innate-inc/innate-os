# Request
string primitive_path      # Path to primitive folder (e.g., primitives/minecraft_wave)
string file_path           # Path to single file (alternative to primitive_path)
string primitive_name      # Optional primitive name (if not provided, extracted from path/filename)
string training_params_json  # JSON string of training parameters (batch_size, max_steps, etc.)
---
# Response
bool success
string job_id              # Job ID if successful
string error_message       # Error message if failed



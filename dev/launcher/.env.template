# Local stack workspace configuration
#
# The launcher defaults to this monorepo layout:
#   .
#   ./sim
#   ../innate-cloud-agent
#
# Only set the repo paths below if your checkout lives elsewhere.

# Optional overrides for non-standard checkout locations
# STACK_OS_REPO=/absolute/path/to/innate-os
# STACK_SIM_REPO=/absolute/path/to/innate-os/sim
# STACK_CLOUD_AGENT_DIR=/absolute/path/to/innate-cloud-agent

# Cloud agent modes:
#   hosted       -> use Innate's hosted cloud agent (default)
#   local-image  -> run a local container image defined by STACK_CLOUD_AGENT_IMAGE
#   local-source -> build and run from STACK_CLOUD_AGENT_DIR
STACK_CLOUD_AGENT_MODE=hosted

# Required when STACK_CLOUD_AGENT_MODE=local-image
# STACK_CLOUD_AGENT_IMAGE=ghcr.io/your-org/innate-cloud-agent:latest

STACK_CLOUD_AGENT_PORT=8765
STACK_LOCAL_CLOUD_AGENT_SKIP_AUTH=true

# Simulator behavior
STACK_SIM_AUTO_SETUP=true
STACK_SIM_AUTO_FETCH_DATA=true
STACK_SIM_AUTO_BUILD_FRONTEND=true
STACK_SIM_VISUALIZATION=false
STACK_SIM_LOG_MODE=quiet
STACK_SIM_ARGS=--log-everything
ROSBRIDGE_URI=ws://localhost:9090
SIMULATOR_PORT=8000

# OS container behavior
STACK_OS_ALWAYS_BUILD=true

# Runtime configuration forwarded into the OS and optional local cloud agent
INNATE_SERVICE_KEY=
TELEMETRY_URL=https://logs.innate.bot
CARTESIA_VOICE_ID=6ccbfb76-1fc6-48f7-b71d-91ac6298247b
# Brain log formatting inside Innate OS:
#   compact       -> [INFO] message
#   message-only  -> message
#   ros-default   -> ROS 2 default formatting
INNATE_BRAIN_LOG_PROFILE=message-only
INNATE_BRAIN_LOG_COLOR=true

# Uncomment to point hosted mode at a non-default remote brain endpoint.
# Leave commented to use the default built into the OS launch files.
# BRAIN_WEBSOCKET_URI=wss://agent-v1.innate.bot

# Local cloud-agent keys
OPENAI_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
BAML_LOG_LEVEL=
BAML_VERBOSE=
BAML_LOG=
ROBOT_TYPE=sim
GOOGLE_APPLICATION_CREDENTIALS=
BIGQUERY_PROJECT_ID=innate-agent
BIGQUERY_TOKEN_LOGS_DATASET_ID=
BIGQUERY_AUTH_DATASET_ID=innate_analytics

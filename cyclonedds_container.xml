<!-- cyclonedds_container.xml -->
<CycloneDDS>
  <!-- For domain ID 0 (the default in ROS 2) -->
  <Domain id="0">
    <!-- <General>
      <NetworkInterfaceAddress>0.0.0.0</NetworkInterfaceAddress>
    </General> -->
    <Discovery>
      <Peers>
        <!-- "host.docker.internal" is a special DNS name that points to
             the host's IP when running Docker Desktop on macOS -->
        <Peer address="host.docker.internal"/>
      </Peers>
      <!-- Optional: <ParticipantIndex>1</ParticipantIndex> if multiple participants. -->
    </Discovery>
  </Domain>
</CycloneDDS>

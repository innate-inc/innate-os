<?xml version="1.0"?>
<CycloneDDS>
  <Domain id="0">
    <General>
      <!-- Bind to all interfaces. 
           We'll also DISABLE multicast in Discovery, so 'AllowMulticast=none'. -->
      <AllowMulticast>true</AllowMulticast> 
      <MaxMessageSize>65500B</MaxMessageSize>
    </General>

    <!-- We'll do minimal logs, or config-level. You can set trace if you want. -->
    <Tracing>
      <Verbosity>config</Verbosity>
      <OutputFile>stdout</OutputFile>
    </Tracing>

    <Discovery>
      <Peers>
        <!-- If you do NOT know container IP, you can leave this empty 
             and rely on container->host unicast. But ideally, you do know it. -->
        <Peer address="127.0.0.1"/>
      </Peers>
      <Ports>
        <!-- We'll pick a base port different from the usual 7400. 
             E.g., let's do 7600 or something to avoid conflicts. -->
        <Base>7600</Base>
      </Ports>

      <ParticipantIndex>1</ParticipantIndex>
      <!-- This is good if you might add more participants on the same machine. -->
      <MaxAutoParticipantIndex>10</MaxAutoParticipantIndex>
    </Discovery>
  </Domain>
</CycloneDDS>
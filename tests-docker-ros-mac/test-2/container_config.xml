<!-- container_config.xml -->
<profiles>
  <participant profile_name="unicast_participant">
    <rtps>
      <builtin>
        <avoid_builtin_multicast>true</avoid_builtin_multicast>

        <!-- The container will attempt to discover the host by contacting "host.docker.internal:7410". -->
        <initialPeersList>
          <locator>
            <udpv4>
              <address>host.docker.internal</address>
              <port>7410</port>
            </udpv4>
          </locator>
        </initialPeersList>

        <!-- The container itself will LISTEN on 0.0.0.0:7410 for discovery from the host. -->
        <metatrafficUnicastLocatorList>
          <locator>
            <udpv4>
              <address>0.0.0.0</address>
              <port>7410</port>
            </udpv4>
          </locator>
        </metatrafficUnicastLocatorList>
      </builtin>

      <port>
        <portBase>7400</portBase>
        <domainIdGain>1</domainIdGain>
        <participantIDGain>1</participantIDGain>
      </port>
    </rtps>
  </participant>
</profiles>
